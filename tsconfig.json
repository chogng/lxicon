{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",          // 支持现代模块化体系
    "moduleResolution": "NodeNext",
    "declaration": true,           // ⚠️ 关键：自动生成 .d.ts 类型文件
    "outDir": "./dist",            // ⚠️ 关键：所有编译后的代码输出到 dist
    "rootDir": "./src-generated",  // 临时存放脚本生成的 ts 代码目录
    "strict": true,
    "skipLibCheck": true
  }
}